# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (public; safe to expose, guarded by RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# --- Canonical site origin ---
# Every canonical, OG tag, sitemap entry and RSS link is built from this.
# It must be the production origin with no trailing slash. Getting this wrong
# points canonicals at the wrong host, which is why it is no longer derived
# from window.location.
NEXT_PUBLIC_SITE_URL=https://blog.stephenakintayofoundation.org

# --- Server-only. Never prefix with NEXT_PUBLIC_. ---
# Used by the revalidate webhook to authenticate Supabase callbacks.
REVALIDATE_SECRET=<random-string>

# Cron publish endpoint (/api/cron/publish)
CRON_SECRET=<random-string>

# Newsletter HMAC (same value as Supabase Edge Function secret NEWSLETTER_TOKEN_SECRET)
NEWSLETTER_TOKEN_SECRET=<random-string>

# Service role — server only; used for confirm/reactivate, campaigns, views, webhooks
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Resend (transactional + campaign email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@stephenakintayofoundation.org
RESEND_FROM_NAME=Stephen Akintayo Foundation

# Optional analytics (omit to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Stripe donations (omit to disable /donate checkout)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional publishable key if you add client Elements later
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Optional error tracking (wire @sentry/nextjs when ready — see README)
SENTRY_DSN=

# Note: the unsubscribe Edge Function's NEWSLETTER_TOKEN_SECRET and
# SUPABASE_SERVICE_ROLE_KEY also live in Supabase function secrets.
# See supabase/functions/README.md.
